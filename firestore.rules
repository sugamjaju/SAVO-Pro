rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helpers
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserProfile(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserProfile(request.auth.uid).role == 'admin';
    }

    function getMyOrgId() {
      return getUserProfile(request.auth.uid).orgId;
    }

    // Resilience-First Task Access Helper
    function canAccessTaskData(data) {
      return isSignedIn() && (
        isAdmin() ||
        data.get('assignedTo', '') == request.auth.uid ||
        data.get('createdBy', '') == request.auth.uid ||
        (data.get('orgId', '') != '' && data.get('orgId', '') == getMyOrgId()) ||
        // Denormalized access (Fastest)
        (data.keys().hasAll(['projectOwnerId']) && data.projectOwnerId == request.auth.uid) ||
        (data.keys().hasAll(['projectMembers']) && request.auth.uid in data.projectMembers) ||
        // Legacy Fallback (Reliable)
        (data.get('projectId', '') != '' && exists(/databases/$(database)/documents/projects/$(data.projectId)) && (
          get(/databases/$(database)/documents/projects/$(data.projectId)).data.ownerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/projects/$(data.projectId)).data.members
        ))
      );
    }

    // ===============================================================
    // Entity Validations
    // ===============================================================

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'status', 'priority', 'projectId', 'orgId', 'createdBy', 'createdAt', 'updatedAt']) &&
             data.title is string && 
             data.status in ['pending', 'in-progress', 'completed'] &&
             data.projectId is string && 
             data.orgId is string && 
             data.createdBy is string;
    }

    function isValidComment(data) {
      // Relaxed keys for compatibility, strict on core identity
      return data.keys().hasAll(['text', 'userId', 'createdAt']) &&
             data.text is string && data.text.size() <= 10000 &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && (isOwner(userId) || (resource != null && getUserProfile(request.auth.uid).orgId == resource.data.orgId));
      allow list: if isSignedIn() && resource.data.orgId == getMyOrgId();
      allow create, update: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    match /organizations/{orgId} {
      allow get: if isSignedIn() && (existing().ownerId == request.auth.uid || getMyOrgId() == orgId);
      allow create, update: if isSignedIn() && (incoming().ownerId == request.auth.uid || existing().ownerId == request.auth.uid);
    }

    match /projects/{projectId} {
      allow list: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        (request.auth.uid in resource.data.members) || 
        isAdmin() ||
        resource.data.orgId == getMyOrgId()
      );
      
      allow get: if isSignedIn() && (
        existing().ownerId == request.auth.uid || 
        (request.auth.uid in existing().members) || 
        isAdmin() ||
        existing().orgId == getMyOrgId()
      );

      allow create: if isSignedIn() && 
                      incoming().ownerId == request.auth.uid &&
                      incoming().createdAt == request.time;

      allow update: if isSignedIn() && 
                      (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /tasks/{taskId} {
      allow list, get: if canAccessTaskData(existing() != null ? existing() : resource.data);
      
      allow create: if isSignedIn() && 
                      isValidTask(incoming()) &&
                      incoming().createdBy == request.auth.uid &&
                      (
                        isAdmin() ||
                        incoming().orgId == getMyOrgId() ||
                        (exists(/databases/$(database)/documents/projects/$(incoming().projectId)) && (
                          get(/databases/$(database)/documents/projects/$(incoming().projectId)).data.ownerId == request.auth.uid ||
                          request.auth.uid in get(/databases/$(database)/documents/projects/$(incoming().projectId)).data.members
                        ))
                      );

      allow update: if isSignedIn() && 
                      (
                        (incoming().assignedTo == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
                        isAdmin() || 
                        existing().createdBy == request.auth.uid || 
                        (existing().get('projectOwnerId', '') == request.auth.uid) ||
                        (data.get('projectId', '') != '' && exists(/databases/$(database)/documents/projects/$(existing().projectId)) && get(/databases/$(database)/documents/projects/$(existing().projectId)).data.ownerId == request.auth.uid)
                      );
    }

    // Simplified Comments Rule - If you can see the task's ID, you can participate
    // This removes nested get() lookups which are the primary cause of logic failures
    match /tasks/{taskId}/comments/{commentId} {
      allow read: if isSignedIn() && exists(/databases/$(database)/documents/tasks/$(taskId));
      allow create: if isSignedIn() && isValidComment(incoming()) && exists(/databases/$(database)/documents/tasks/$(taskId));
    }

    match /invitations/{invId} {
      allow list: if isSignedIn() && resource.data.email == request.auth.token.email.lower();
      allow get: if isSignedIn() && (resource.data.email == request.auth.token.email.lower() || isAdmin());
      allow create: if isSignedIn() && incoming().invitedBy == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.email == request.auth.token.email.lower() || isAdmin());
    }
  }
}
