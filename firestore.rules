rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helpers
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // RBAC: Roles are stored in the user profile. We use get() to fetch it.
    function getUserProfile(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserProfile(request.auth.uid).role == 'admin';
    }

    function getMyOrgId() {
      return getUserProfile(request.auth.uid).orgId;
    }

    // ===============================================================
    // Entity Validations
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'orgId', 'createdAt']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 128 &&
             data.role in ['admin', 'member'] &&
             data.orgId is string && data.orgId.size() <= 64 &&
             data.createdAt is timestamp;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'ownerId', 'orgId', 'members', 'createdAt']) &&
             data.name is string && data.name.size() <= 128 &&
             data.ownerId is string && data.ownerId.size() <= 128 &&
             data.orgId is string && data.orgId.size() <= 64 &&
             data.members is list && data.members.size() <= 100 &&
             data.createdAt is timestamp;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'status', 'priority', 'projectId', 'orgId', 'createdBy', 'createdAt', 'updatedAt']) &&
             data.title is string && data.title.size() <= 128 &&
             data.status in ['pending', 'in-progress', 'completed'] &&
             data.priority in ['low', 'medium', 'high'] &&
             data.projectId is string && data.projectId.size() <= 64 &&
             data.orgId is string && data.orgId.size() <= 64 &&
             data.createdBy is string && data.createdBy.size() <= 128 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && (isOwner(userId) || (resource != null && getUserProfile(request.auth.uid).orgId == resource.data.orgId));
      allow list: if isSignedIn() && resource.data.orgId == getMyOrgId();
      
      allow create: if isOwner(userId) && 
                      isValidId(userId) &&
                      isValidUser(incoming()) && 
                      incoming().role == 'member' && 
                      incoming().createdAt == request.time;
      
      allow update: if (isOwner(userId) || isAdmin()) && 
                      isValidId(userId) &&
                      isValidUser(incoming()) &&
                      incoming().uid == existing().uid &&
                      incoming().orgId == existing().orgId &&
                      incoming().createdAt == existing().createdAt &&
                      (isOwner(userId) ? incoming().role == existing().role : true);
    }

    match /organizations/{orgId} {
      allow get: if isSignedIn() && isValidId(orgId) && (existing().ownerId == request.auth.uid || getMyOrgId() == orgId);
      allow list: if false;
      
      allow create: if isSignedIn() && isValidId(orgId) && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(orgId) && existing().ownerId == request.auth.uid;
    }

    match /projects/{projectId} {
      allow list: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        (request.auth.uid in resource.data.members) || 
        isAdmin()
      );
      
      allow get: if isSignedIn() && isValidId(projectId) && (
        existing().ownerId == request.auth.uid || 
        (request.auth.uid in existing().members) || 
        isAdmin()
      );

      allow create: if isSignedIn() && 
                      isValidId(projectId) &&
                      isValidProject(incoming()) && 
                      incoming().ownerId == request.auth.uid &&
                      incoming().orgId == getMyOrgId() &&
                      incoming().createdAt == request.time;

      allow update: if isSignedIn() && 
                      isValidId(projectId) &&
                      isValidProject(incoming()) &&
                      incoming().orgId == existing().orgId &&
                      incoming().createdAt == existing().createdAt &&
                      (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /tasks/{taskId} {
      allow list: if isSignedIn() && (
        resource.data.assignedTo == request.auth.uid || 
        resource.data.createdBy == request.auth.uid ||
        isAdmin() ||
        (get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.ownerId == request.auth.uid) ||
        (request.auth.uid in get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.members)
      );

      allow get: if isSignedIn() && isValidId(taskId) && (
        existing().assignedTo == request.auth.uid || 
        existing().createdBy == request.auth.uid ||
        isAdmin() ||
        (get(/databases/$(database)/documents/projects/$(existing().projectId)).data.ownerId == request.auth.uid) ||
        (request.auth.uid in get(/databases/$(database)/documents/projects/$(existing().projectId)).data.members)
      );

      allow create: if isSignedIn() && 
                      isValidId(taskId) &&
                      isValidTask(incoming()) &&
                      incoming().createdBy == request.auth.uid &&
                      incoming().orgId == getMyOrgId() &&
                      incoming().createdAt == request.time &&
                      (
                        get(/databases/$(database)/documents/projects/$(incoming().projectId)).data.ownerId == request.auth.uid ||
                        request.auth.uid in get(/databases/$(database)/documents/projects/$(incoming().projectId)).data.members
                      );

      allow update: if isSignedIn() && 
                      isValidId(taskId) &&
                      isValidTask(incoming()) &&
                      incoming().orgId == existing().orgId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().createdBy == existing().createdBy &&
                      (
                        (incoming().assignedTo == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
                        (isAdmin() || existing().createdBy == request.auth.uid || get(/databases/$(database)/documents/projects/$(existing().projectId)).data.ownerId == request.auth.uid)
                      );
    }

    match /tasks/{taskId}/comments/{commentId} {
      allow read: if isSignedIn() && 
                     isValidId(taskId) && isValidId(commentId) &&
                     (get(/databases/$(database)/documents/tasks/$(taskId)).data.orgId == getMyOrgId());
      
      allow create: if isSignedIn() && 
                       isValidId(taskId) && isValidId(commentId) &&
                       incoming().userId == request.auth.uid &&
                       incoming().createdAt == request.time &&
                       (get(/databases/$(database)/documents/tasks/$(taskId)).data.orgId == getMyOrgId());
    }
  }
}
